# ================================================================================
# Arbeitszeitapp Deployment Configuration
# ================================================================================
# Copy this file to .env and fill in your specific values.
#
# CONFIGURATION METHODS:
# ----------------------
# This deployment supports two configuration approaches:
#
# 1. ENVIRONMENT VARIABLES (this file):
#    - Simple key=value pairs in this .env file
#    - Automatically loaded by Docker Compose
#    - Suitable for most configurations
#
# 2. FILE-BASED CONFIGURATION:
#    - JSON configuration files (mailconfig.json, profiling.json)
#    - Mounted as volumes into the container
#    - Takes precedence over environment variables
#    - Use MAIL_CONFIG_PATH and PROFILING_CONFIG_PATH to specify paths
#
# VARIABLE REQUIREMENTS BY DEPLOYMENT MODE:
# =========================================
#
# HTTP MODE (development):
#   Required: SERVER_NAME, POSTGRES_*, MAIL_* (for user registration/auth)
#   Optional: PROFILING_*, ARBEITSZEITAPP_IMAGE
#
# HTTPS MODE (manual certificates):
#   Required: SERVER_NAME, POSTGRES_*, MAIL_*, certificates in certs/ folder
#   Optional: PROFILING_*, ARBEITSZEITAPP_IMAGE
#
# LETSENCRYPT MODE (automatic certificates):
#   Required: SERVER_NAME, POSTGRES_*, MAIL_*, DEFAULT_EMAIL, LETSENCRYPT_EMAIL
#   Optional: PROFILING_*, ARBEITSZEITAPP_IMAGE
#
# ================================================================================

# -- Docker Image Settings (OPTIONAL) --
# Override the default arbeitszeitapp image location
# Useful for using pre-built images from a registry
# Default: arbeitszeitapp:latest
# ARBEITSZEITAPP_IMAGE=myregistry/arbeitszeitapp:latest

# -- Server Configuration (REQUIRED for production) --
# Choose between Flask development server or uWSGI production server
# Options: flask, dev, development (for Flask dev server)
#          uwsgi, prod, production (for uWSGI production server)
# Default: flask
SERVER_TYPE=flask

# -- General Settings (REQUIRED) --
# Your server's public domain name
# CRITICAL: For HTTPS/Let's Encrypt modes, this MUST be a real domain pointing to your server
# Examples: app.example.com, arbeitszeit.mycompany.com
# Default for HTTP mode: localhost
SERVER_NAME=app.example.com

# -- Database Credentials (REQUIRED) --
# These settings configure the PostgreSQL database
# DATABASE_URL is automatically constructed: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db/${POSTGRES_DB}
# 
# SECURITY WARNING: Change the default password in production!
POSTGRES_DB=arbeitszeitapp
POSTGRES_USER=arbeitszeitapp
POSTGRES_PASSWORD=your-secure-password

# -- Let's Encrypt Settings (REQUIRED for letsencrypt mode) --
# Email address for Let's Encrypt certificate registration and notifications
# This email receives important notifications about certificate expiration
# MUST be a valid email address that you monitor
DEFAULT_EMAIL=admin@example.com

# You can optionally override the email for a specific certificate
# If not set, DEFAULT_EMAIL will be used
LETSENCRYPT_EMAIL=admin@example.com

# ================================================================================
# MAIL CONFIGURATION (REQUIRED)
# ================================================================================
# Email functionality is REQUIRED for core application features:
# - User registration and email verification
# - Password reset emails  
# - System notifications
# - Authentication workflows
#
# The application WILL show warnings and may not function properly without
# proper email configuration. This is validated at startup.
#
# CONFIGURATION METHODS:
# 1. Environment variables (below) - Simple and direct
# 2. JSON file - Create mailconfig.json and set MAIL_CONFIG_PATH
#
# If using JSON file, see docker-deployment/mailconfig.json.example for format
# ================================================================================

# -- Mail Configuration via Environment Variables (REQUIRED) --
# Configure SMTP settings for sending emails from the application
# ALL of these settings are required for proper operation:
# - MAIL_SERVER, MAIL_USERNAME, MAIL_PASSWORD, MAIL_DEFAULT_SENDER

# Gmail example (recommended for testing):
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password  # Use App Password, not your regular password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# Other SMTP provider examples:
# 
# Office 365:
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
#
# Amazon SES:
# MAIL_SERVER=email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
#
# Custom SMTP:
# MAIL_SERVER=mail.yourcompany.com
# MAIL_PORT=587  # or 465 for SSL, 25 for unsecured

# ================================================================================
# PROFILING CONFIGURATION (OPTIONAL)
# ================================================================================
# Flask-profiler for performance monitoring and debugging
# Only enable in development or staging environments
#
# CONFIGURATION METHODS:
# 1. Environment variables (below) - Quick setup
# 2. JSON file - Create profiling.json and set PROFILING_CONFIG_PATH
#
# If using JSON file, see docker-deployment/profiling.json.example for format
# ================================================================================

# -- Profiling Configuration via Environment Variables --
# Set to true to enable performance profiling (NOT recommended for production)
PROFILING_ENABLED=false

# Enable authentication for profiling endpoint (recommended if profiling is enabled)
PROFILING_AUTH_ENABLED=false

# Credentials for accessing profiling data (required if PROFILING_AUTH_ENABLED=true)
PROFILING_USERNAME=admin
PROFILING_PASSWORD=your_profiling_password

# URL endpoint for profiling interface
# Access at: http://yourserver/profiling (or whatever you set here)
PROFILING_ENDPOINT=profiling

# ================================================================================
# FILE-BASED CONFIGURATION PATHS (ADVANCED)
# ================================================================================
# Override default paths for configuration files
# Use these if you want to mount custom config files into the container
# These files take PRECEDENCE over environment variables above
#
# To use file-based configuration:
# 1. Create the JSON configuration file (see mailconfig.json.example and profiling.json.example)
# 2. Mount it into the container using Docker volumes
# 3. Set the path here
#
# EXAMPLE: To mount custom configuration files, add to docker-compose.override.yml:
#
# services:
#   arbeitszeitapp:
#     volumes:
#       - ./mailconfig.json:/app/mailconfig.json:ro
#       - ./profiling.json:/app/profiling.json:ro
#
# For complete instructions, see the "Using File-Based Configurations" 
# section in README.rst
# ================================================================================

# Path to mail configuration JSON file (overrides MAIL_* environment variables)
# MAIL_CONFIG_PATH=/app/mailconfig.json

# Path to profiling configuration JSON file (overrides PROFILING_* environment variables)
# PROFILING_CONFIG_PATH=/app/profiling.json

# ================================================================================
# DEPLOYMENT MODE EXAMPLES
# ================================================================================
#
# DEVELOPMENT (HTTP only):
# ------------------------
# SERVER_TYPE=flask
# SERVER_NAME=localhost
# POSTGRES_PASSWORD=dev123
# MAIL_SERVER=smtp.gmail.com
# MAIL_USERNAME=dev@example.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=dev@example.com
# # Profiling can be enabled for development testing
#
# STAGING (HTTPS with manual certificates):
# ----------------------------------------- 
# SERVER_TYPE=uwsgi
# SERVER_NAME=staging.example.com
# POSTGRES_PASSWORD=staging-secure-password
# MAIL_SERVER=smtp.gmail.com
# MAIL_USERNAME=staging@example.com
# MAIL_PASSWORD=staging-app-password
# MAIL_DEFAULT_SENDER=staging@example.com
# # Place SSL certificates in docker-deployment/certs/
#
# PRODUCTION (Let's Encrypt):
# ---------------------------
# SERVER_TYPE=uwsgi  
# SERVER_NAME=app.example.com
# POSTGRES_PASSWORD=production-very-secure-password
# DEFAULT_EMAIL=admin@example.com
# LETSENCRYPT_EMAIL=admin@example.com
# MAIL_SERVER=smtp.yourcompany.com
# MAIL_USERNAME=noreply@example.com
# MAIL_PASSWORD=production-mail-password
# MAIL_DEFAULT_SENDER=noreply@example.com
# PROFILING_ENABLED=false  # NEVER enable in production
#
# ================================================================================
