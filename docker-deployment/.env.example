# Arbeitszeitapp Deployment Configuration
# Copy this file to .env and fill in your specific values.

# -- Docker Image Settings --
# Override the default arbeitszeitapp image location
# Useful for using pre-built images from a registry
# ARBEITSZEITAPP_IMAGE=myregistry/arbeitszeitapp:latest

# -- Server Configuration --
# Choose between Flask development server or uWSGI production server
# Options: flask, dev, development (for Flask dev server)
#          uwsgi, prod, production (for uWSGI production server)
# Default: flask
SERVER_TYPE=flask

# -- General Settings --
# Your server's public domain name
SERVER_NAME=app.example.com

# -- Database Credentials --
# DATABASE_URL is automatically constructed from the values below
# Format: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db/${POSTGRES_DB}

# Individual database settings for the postgres container
POSTGRES_DB=arbeitszeitapp
POSTGRES_USER=arbeitszeitapp
POSTGRES_PASSWORD=your-secure-password

# -- Let's Encrypt Settings --
# The email address for Let's Encrypt registration and notifications.
# This is used as the default for all certificates.
DEFAULT_EMAIL=admin@example.com

# You can optionally override the email for a specific certificate.
# If not set, DEFAULT_EMAIL will be used.
LETSENCRYPT_EMAIL=admin@example.com

# -- Mail Configuration (Required) --
# Configure SMTP settings for sending emails from the application
# Email functionality is required for user registration, password resets, and notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# -- Profiling Configuration (Optional) --
# Configure Flask-profiler for performance monitoring
# Leave PROFILING_ENABLED=false to disable profiling
PROFILING_ENABLED=false
PROFILING_AUTH_ENABLED=false
PROFILING_USERNAME=admin
PROFILING_PASSWORD=your_profiling_password
PROFILING_ENDPOINT=profiling

# -- File-Based Configuration Paths (Optional) --
# Override default paths for configuration files
# Use these if you want to mount custom config files into the container
# MAIL_CONFIG_PATH=/app/mailconfig.json
# PROFILING_CONFIG_PATH=/app/profiling.json
