# Arbeitszeitapp Deployment Configuration
# Copy this file to .env and fill in your specific values.

# -- General Settings --
# Your server's public domain name
SERVER_NAME=app.example.com

# -- Database Credentials --
# The full database connection string for the application
DATABASE_URL=postgresql://arbeitszeitapp:your-secure-password@db/arbeitszeitapp

# Individual database settings for the postgres container
POSTGRES_DB=arbeitszeitapp
POSTGRES_USER=arbeitszeitapp
POSTGRES_PASSWORD=your-secure-password

# -- Let's Encrypt Settings --
# The email address for Let's Encrypt registration and notifications.
# This is used as the default for all certificates.
DEFAULT_EMAIL=admin@example.com

# You can optionally override the email for a specific certificate.
# If not set, DEFAULT_EMAIL will be used.
LETSENCRYPT_EMAIL=admin@example.com
